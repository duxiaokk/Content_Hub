# Publishing settings
ADO_PUBLISH_ENABLED=true
ADO_PUBLISH_ENDPOINT_URL=http://127.0.0.1:8000/api/internal/agent/drafts
ADO_INTERNAL_TOKEN=local-dev-internal-token
ADO_PUBLISH_TIMEOUT_SECONDS=15
ADO_SOURCE_PLATFORM=youtube

# Optional scheduler registration
SCHEDULER_CENTER_URL=http://127.0.0.1:8010
SCHEDULER_INTERNAL_TOKEN=local-dev-scheduler-token
ADO_REPOST_INTERNAL_TOKEN=local-dev-scheduler-token
ADO_REPOST_BASE_URL=http://127.0.0.1:8002
ADO_REPOST_AGENT_KEY=content-bridge
ADO_REPOST_AGENT_NAME=content-bridge

# Shared memory defaults
SHARED_MEMORY_NAMESPACE=content-bridge
SHARED_MEMORY_REDIS_URL=redis://localhost:6379/0
SHARED_MEMORY_REDIS_KEY_PREFIX=shared_memory:
SHARED_MEMORY_SQLITE_PATH=./data/shared_memory.db
