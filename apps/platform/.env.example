# =============================================================================
# Ado_Jk Multi-Agent Orchestration Platform — Environment Variables
# =============================================================================
# 使用方法：复制此文件为 .env，按环境修改对应值。
#   cp .env.example .env
#
# 配置分组说明：
#   [REQUIRED]  — 必须配置，否则服务无法启动
#   [DEV]       — 本地开发默认值
#   [TEST]      — 测试环境推荐值
#   [PROD]      — 生产环境必须审查并替换
# =============================================================================

# ---------------------------------------------------------------------------
# 1. 数据库 (Database)
# ---------------------------------------------------------------------------
# [REQUIRED] 主数据库连接地址。
# DEV:  SQLite 文件存储，无需额外服务
# TEST: 使用独立的测试数据库文件，避免污染开发数据
# PROD: 切换为 PostgreSQL / MySQL
DATABASE_URL=sqlite:///./blog.db
# DATABASE_URL=sqlite:///./blog_test.db          # [TEST]
# DATABASE_URL=postgresql://user:pass@host:5432/blog  # [PROD]

# [OPTIONAL] MySQL 兼容模式（仅当 DATABASE_URL 为空时生效）
# USE_MYSQL=false
# DB_USER=
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=my_blog_db

# ---------------------------------------------------------------------------
# 2. 安全与认证 (Security & Auth)
# ---------------------------------------------------------------------------
# [REQUIRED] JWT 签名密钥。
# DEV:  任意字符串
# PROD: 使用 openssl rand -hex 32 生成，并通过密钥管理服务注入
SECRET_KEY=change-me-in-production

# JWT 算法 (HS256 / RS256 / ES256)
ALGORITHM=HS256

# 令牌有效期
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# 管理员用户名（注册/首次启动时使用）
ADMIN_USERNAME=Ado_Jk

# 平台标签列表（逗号分隔，首页展示用）
TECH_TAGS=Python,FastAPI,SQLAlchemy,SQLite

# ---------------------------------------------------------------------------
# 3. Redis 缓存 (Redis)
# ---------------------------------------------------------------------------
# [OPTIONAL] 不设置则禁用 Redis 缓存（评论 SSE、记忆池等功能降级）
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# 4. 调度中心 (Scheduler Center) — 主服务连接调度中心的配置
# ---------------------------------------------------------------------------
# [REQUIRED] 调度中心地址
# DEV:  本地运行，端口 8010
# PROD: 内网地址或 K8s Service DNS
SCHEDULER_CENTER_URL=http://127.0.0.1:8010

# [REQUIRED] 调度中心内部鉴权令牌（需与调度中心 SCHEDULER_INTERNAL_TOKEN 一致）
SCHEDULER_INTERNAL_TOKEN=local-dev-scheduler-token

# ---------------------------------------------------------------------------
# 5. LLM / AI Agent 配置 (LLM Configuration)
# ---------------------------------------------------------------------------
# [REQUIRED] LLM API 密钥
# DEV:  可使用 DeepSeek / OpenAI / 本地模型
# PROD: 通过密钥管理服务注入
LLM_API_KEY=sk-your-api-key-here

# LLM API 地址
# DeepSeek:  https://api.deepseek.com
# OpenAI:    https://api.openai.com/v1
# 本地:      http://localhost:11434/v1  (Ollama)
LLM_BASE_URL=https://api.deepseek.com

# LLM 模型名称
# DeepSeek:  deepseek-v4-flash / deepseek-chat
# OpenAI:    gpt-4o-mini / gpt-4o
# Ollama:    llama3 / qwen2.5
LLM_MODEL=deepseek-v4-flash

# 使用 Mock LLM（不调用真实 API，返回占位内容）
# DEV:  true（无 API Key 时）
# PROD: false
MOCK_LLM=false

# ---------------------------------------------------------------------------
# 6. 内部 Agent 通信 (Internal Agent)
# ---------------------------------------------------------------------------
# [REQUIRED] Agent 内部 API 鉴权令牌（与 Agent 端配置一致）
INTERNAL_AGENT_TOKEN=local-dev-internal-token

# ---------------------------------------------------------------------------
# 7. 服务端口 (Server Ports)
# ---------------------------------------------------------------------------
# [OPTIONAL] 主服务监听端口（默认 8000）
# PLATFORM_PORT=8000

# [OPTIONAL] 主服务监听地址
# PLATFORM_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# 8. 日志 (Logging)
# ---------------------------------------------------------------------------
# [OPTIONAL] 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# [OPTIONAL] 日志输出目录（默认 stdout）
# LOG_DIR=./logs

# ---------------------------------------------------------------------------
# 9. 可观测性 (Observability) — P5
# ---------------------------------------------------------------------------
# [OPTIONAL] 是否启用 OpenTelemetry 分布式追踪
# OTEL_ENABLED=true

# [OPTIONAL] OTLP Exporter 地址（Jaeger gRPC）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# [OPTIONAL] 当前服务名（用于 Trace/Metrics/Labels）
# OTEL_SERVICE_NAME=platform

# [OPTIONAL] 是否启用 Prometheus 指标采集 + /metrics 端点
# METRICS_ENABLED=true

# [OPTIONAL] 日志格式: json (结构化) / console (可读)
# LOG_FORMAT=json

# [OPTIONAL] Grafana 管理员密码（仅在 compose 中生效）
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# =============================================================================
# 10. Content Hub MVP 閰嶇疆 (Content Hub MVP)
# =============================================================================
# [OPTIONAL] 鏄惁鍚敤鏃ユ姤鐢熸垚
CONTENT_HUB_ENABLE_DIGEST=true

# [OPTIONAL] 榛樿鏀瑰啓閰嶇疆鏂囦欢鍚嶏紙瀵瑰簲 rewrite_profiles.name锛
CONTENT_HUB_DEFAULT_REWRITE_PROFILE=zh_tech_blog

# [OPTIONAL] 鏃ユ姤 Markdown 杈撳嚭鐩綍
CONTENT_HUB_DIGEST_OUTPUT_DIR=.tmp/digests

# [OPTIONAL] 瀹℃牳鏄惁蹇呴€夛紙false=璺宠繃瀹℃牳鐩存帴鍙戝竷锛
CONTENT_HUB_REVIEW_REQUIRED=true

# [OPTIONAL] 榛樿鍏抽敭璇嶇櫧鍚嶅崟锛堥€楀彿鍒嗛殧锛
CONTENT_HUB_FILTER_KEYWORDS=agent,rag,llm,openai

# [OPTIONAL] 榛樿鍏抽敭璇嶉粦鍚嶅崟锛堥€楀彿鍒嗛殧锛
CONTENT_HUB_FILTER_EXCLUDE_KEYWORDS=鎷涜仒,骞垮憡

# [OPTIONAL] 鏄惁鍚敤 GitHub Trending 鎶撳彇
CONTENT_HUB_GITHUB_TRENDING_ENABLED=true

# [OPTIONAL] 鏄惁鍚敤 Reddit 鎶撳彇
CONTENT_HUB_REDDIT_ENABLED=true

# [OPTIONAL] 璋冨害鍣ㄦ槸鍚﹀惎鐢ㄥ畾鏃朵换鍔
CONTENT_HUB_SCHEDULER_ENABLED=true

# [OPTIONAL] 鍓嶇鎵嬪姩瑙﹀彂鍐呴儴浠诲姟鏃朵娇鐢ㄧ殑 token
VITE_INTERNAL_API_TOKEN=local-dev-internal-token
