# =============================================================================
# Ado_Jk Multi-Agent Orchestration Platform — 生产环境变量模板
# =============================================================================
# 使用前:
#   1. 复制为 .env:  cp .env.production .env
#   2. 修改所有 <生成强密码> 占位符
#   3. 设置 LLM_API_KEY 为真实 API 密钥
#   4. 运行: docker compose up -d
# =============================================================================

# ---------------------------------------------------------------------------
# 安全（生产环境必须修改）
# ---------------------------------------------------------------------------
# 用 openssl rand -hex 32 生成
SECRET_KEY=<生成64位随机字符串>
SCHEDULER_INTERNAL_TOKEN=<生成32位随机字符串>
INTERNAL_AGENT_TOKEN=<生成32位随机字符串>

# ---------------------------------------------------------------------------
# 数据库
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=<生成强密码>
# 开发时暴露端口，生产环境设为空字符串跳过端口映射
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# 开发时暴露端口，生产环境设为空字符串跳过端口映射
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# LLM 配置（生产环境请使用真实 API Key）
# ---------------------------------------------------------------------------
# DeepSeek (推荐)
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# 或使用 OpenAI
# LLM_API_KEY=sk-your-openai-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# 设为 true 使用模拟 LLM（不需要 API Key，仅用于测试）
MOCK_LLM=false

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=<生成强密码>

# ---------------------------------------------------------------------------
# 日志
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# 平台配置
# ---------------------------------------------------------------------------
PLATFORM_PORT=8000
ADMIN_USERNAME=admin
TECH_TAGS=Python,FastAPI,SQLAlchemy,PostgreSQL,Redis,Agent,AI

# ---------------------------------------------------------------------------
# 可观测性
# ---------------------------------------------------------------------------
OTEL_ENABLED=true
METRICS_ENABLED=true
