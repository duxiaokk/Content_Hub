# =============================================================================
# Scheduler Center — Environment Variables
# =============================================================================
# 使用方法：复制此文件为 scheduler_center/.env，按环境修改对应值。
#   cp scheduler_center/.env.example scheduler_center/.env
#
# 配置分组说明：
#   [REQUIRED]  — 必须配置
#   [DEV]       — 本地开发默认值
#   [TEST]      — 测试环境推荐值
#   [PROD]      — 生产环境必须审查并替换
# =============================================================================

# ---------------------------------------------------------------------------
# 1. 数据库 (Database)
# ---------------------------------------------------------------------------
# DEV:  SQLite WAL 模式
# PROD: 切换为 PostgreSQL
SCHEDULER_DATABASE_URL=
SCHEDULER_DB_PATH=./scheduler.db
# SCHEDULER_DB_PATH=./scheduler_test.db          # [TEST]

# SQLite 连接池配置（仅 SQLite 生效）
SCHEDULER_DB_POOL_SIZE=30
SCHEDULER_DB_MAX_OVERFLOW=60
SCHEDULER_DB_POOL_TIMEOUT_SECONDS=30
SCHEDULER_SQLITE_BUSY_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# 2. 鉴权 (Auth)
# ---------------------------------------------------------------------------
# [REQUIRED] 内部 API 鉴权令牌（所有调用方需携带 x-internal-token 头）
# PROD: 使用 openssl rand -hex 32 生成
SCHEDULER_INTERNAL_TOKEN=local-dev-scheduler-token

# ---------------------------------------------------------------------------
# 3. Redis (可选，启用 Fast Submit 快速投递模式)
# ---------------------------------------------------------------------------
SCHEDULER_REDIS_URL=redis://127.0.0.1:6379/0
SCHEDULER_REDIS_PREFIX=scheduler

# 启用 Redis 快速投递（任务先写入 Redis 队列，再异步落库 SQLite）
SCHEDULER_FAST_SUBMIT_ENABLED=false
SCHEDULER_FAST_SUBMIT_TASK_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# 4. 调度器 (Dispatcher)
# ---------------------------------------------------------------------------
# 最大并发任务数
# DEV:  4
# PROD: 根据 Agent 数量和机器资源调整
SCHEDULER_MAX_CONCURRENCY=100

# 轮询间隔（秒），越小调度延迟越低，但 CPU 消耗越高
SCHEDULER_POLL_INTERVAL_SECONDS=0.05

# 默认重试配置（任务级默认值，单任务可覆盖）
SCHEDULER_DEFAULT_MAX_RETRIES=2
SCHEDULER_DEFAULT_RETRY_DELAY_SECONDS=1

# HTTP 调用 Agent 的超时时间（秒）
SCHEDULER_HTTP_TIMEOUT_SECONDS=5

# 禁用调度器（仅启动 API 服务，不执行任务调度）
SCHEDULER_DISABLE_DISPATCHER=false

# 提交任务时写入日志
SCHEDULER_SUBMIT_WRITE_LOGS=false

# ---------------------------------------------------------------------------
# 5. Agent 配置
# ---------------------------------------------------------------------------
# Agent 端点列表（逗号分隔），启动时静态注册
SCHEDULER_AGENT_ENDPOINTS=http://127.0.0.1:8020

# Agent 统一请求路径
SCHEDULER_AGENT_REQUEST_PATH=/api/internal/agent/run

# Agent 鉴权令牌（调度中心调用 Agent 时携带）
SCHEDULER_AGENT_TOKEN=

# Agent 注册偏好：true=优先从数据库读取已注册 Agent，false=仅使用静态配置
SCHEDULER_AGENT_REGISTRY_PREFER_DB=true

# Agent 心跳 TTL（秒），超时未心跳标记为不可用
SCHEDULER_AGENT_HEARTBEAT_TTL_SECONDS=120.0

# Agent 健康检查缓存时间（秒）
SCHEDULER_AGENT_HEALTH_CACHE_SECONDS=10.0

# Agent 健康检查超时时间（秒）
SCHEDULER_AGENT_HEALTH_TIMEOUT_SECONDS=2.0

# ---------------------------------------------------------------------------
# 6. CORS
# ---------------------------------------------------------------------------
# 允许的前端域名（逗号分隔）
SCHEDULER_CORS_ALLOW_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# 7. 服务端口
# ---------------------------------------------------------------------------
# [OPTIONAL] 调度中心监听端口
# DEV:  8010
# PROD: 按部署规划调整
# SCHEDULER_PORT=8010
# SCHEDULER_HOST=127.0.0.1
